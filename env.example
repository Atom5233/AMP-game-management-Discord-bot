# AMP Discord ChatOps Engine — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Discord
BOT_TOKEN=your_discord_bot_token_here
ALLOWED_ROLE_ID=0                        # Role ID required to use the dashboard (0 = anyone)
DASHBOARD_CHANNEL_ID=                    # Channel ID where the dashboard and alerts are posted
VOICE_LOBBY_ID=0                         # Voice channel ID for auto-provisioning (0 = disabled)

# AMP
AMP_URL=http://192.168.X.X:8080
AMP_USER=your_amp_username
AMP_PASSWORD=your_amp_password

# Hardware (Raspberry Pi GPIO)
GPIO_PIN=0                               # GPIO pin number for PC power control
GPIOSET_PATH=/usr/bin/gpioset

# Tuning
WATCH_INTERVAL=120                       # Seconds between status polls (keep high on Pi 1B)
IDLE_TIMEOUT=1800                        # Seconds of 0 players before host PC is shut down
